<tr class="border-b border-gray-100 hover:bg-blue-50 cursor-pointer event-row"
    data-action="click->snoo#showPayload"
    data-raw="<%= event.raw_payload %>">
  <% display_time = event.event_time&.in_time_zone %>
  <% gap_seconds = if event.event_time && previous_event&.event_time
                     (event.event_time - previous_event.event_time).to_i
                   end %>
  <td class="py-2 px-3 whitespace-nowrap text-xs" title="<%= display_time&.strftime("%Y-%m-%d %H:%M:%S.%L %Z") %>">
    <%= if display_time
          display_time.to_date == Time.zone.today ? display_time.strftime("%-l:%M:%S %p") : display_time.strftime("%b %-d, %-l:%M %p")
        else
          "-"
        end %>
  </td>
  <td class="py-2 px-3 whitespace-nowrap text-xs text-gray-500" title="<%= gap_seconds&.positive? ? "#{gap_seconds}s since prior event" : nil %>">
    <%= event_gap_label(event, previous_event) %>
  </td>
  <td class="py-2 px-3">
    <span class="px-2 py-0.5 rounded text-xs font-medium
      <%= case event.resolved_event_type
          when 'cry' then 'bg-yellow-100 text-yellow-800'
          when 'safety_clip' then 'bg-red-100 text-red-800'
          when 'command' then 'bg-blue-100 text-blue-800'
          when 'timer' then 'bg-purple-100 text-purple-800'
          when 'power' then 'bg-orange-100 text-orange-800'
          else 'bg-gray-100 text-gray-800'
          end %>">
      <%= event.resolved_event_type %>
    </span>
  </td>
  <td class="py-2 px-3 font-medium"><%= event.resolved_state %></td>
  <td class="py-2 px-3"><%= event.resolved_level %></td>
  <td class="py-2 px-3">
    <% if event.resolved_hold %>
      <span class="text-orange-600 font-bold">HOLD</span>
    <% else %>
      <span class="text-gray-400">OFF</span>
    <% end %>
  </td>
  <td class="py-2 px-3">
    <span class="<%= event.resolved_left_clip ? 'text-green-600' : 'text-red-600' %>">
      <%= event.resolved_left_clip ? "OK" : "OPEN" %>
    </span>
  </td>
  <td class="py-2 px-3">
    <span class="<%= event.resolved_right_clip ? 'text-green-600' : 'text-red-600' %>">
      <%= event.resolved_right_clip ? "OK" : "OPEN" %>
    </span>
  </td>
  <td class="py-2 px-3">
    <% if event.resolved_sticky_white_noise %>
      <span class="text-blue-600">ON</span>
    <% else %>
      <span class="text-gray-400">OFF</span>
    <% end %>
  </td>
</tr>
