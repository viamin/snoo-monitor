<%
  current_index = SnooControl::STATE_ORDER.index(current_state)
  can_lower = connected && current_index.present? && current_index.positive?
  can_raise = connected && current_index.present? && current_index < SnooControl::STATE_ORDER.length - 1
%>

<div class="bg-white shadow rounded-lg p-6 mb-6">
  <div class="flex items-center justify-between gap-4 mb-4">
    <div>
      <h2 class="text-xl font-semibold">Controls</h2>
      <p class="text-sm text-gray-500">Experimental runtime controls for hold and supported level changes.</p>
    </div>

    <div class="text-sm text-right text-gray-500">
      <div>State: <span class="font-semibold text-gray-900"><%= current_state || "-" %></span></div>
      <div>Hold: <span class="font-semibold <%= current_hold ? 'text-orange-600' : 'text-gray-600' %>"><%= current_hold ? "ON" : "OFF" %></span></div>
    </div>
  </div>

  <% if connected %>
    <div class="grid gap-4 md:grid-cols-2">
      <div class="rounded-lg bg-gray-50 p-4">
        <div class="text-sm font-medium text-gray-700 mb-3">Level</div>
        <div class="flex flex-wrap gap-2">
          <%= form_with url: snoo_level_path, method: :post do %>
            <button type="submit" name="direction" value="down"
                    class="rounded px-4 py-2 text-white <%= can_lower ? 'bg-slate-700 hover:bg-slate-800' : 'bg-slate-300 cursor-not-allowed' %>"
                    <%= can_lower ? nil : 'disabled' %>>
              Lower
            </button>
          <% end %>

          <%= form_with url: snoo_level_path, method: :post do %>
            <button type="submit" name="direction" value="up"
                    class="rounded px-4 py-2 text-white <%= can_raise ? 'bg-blue-600 hover:bg-blue-700' : 'bg-blue-300 cursor-not-allowed' %>"
                    <%= can_raise ? nil : 'disabled' %>>
              Raise
            </button>
          <% end %>
        </div>
        <p class="mt-3 text-xs text-gray-500">Supported states: <span class="font-mono"><%= SnooControl::STATE_ORDER.join(" -> ") %></span></p>
      </div>

      <div class="rounded-lg bg-gray-50 p-4">
        <div class="text-sm font-medium text-gray-700 mb-3">Hold</div>
        <div class="flex flex-wrap gap-2">
          <%= form_with url: snoo_hold_path, method: :post do %>
            <button type="submit" name="hold" value="true"
                    class="rounded px-4 py-2 text-white <%= current_hold ? 'bg-orange-300 cursor-not-allowed' : 'bg-orange-500 hover:bg-orange-600' %>"
                    <%= current_hold ? 'disabled' : nil %>>
              Hold On
            </button>
          <% end %>

          <%= form_with url: snoo_hold_path, method: :post do %>
            <button type="submit" name="hold" value="false"
                    class="rounded px-4 py-2 text-white <%= current_hold ? 'bg-gray-700 hover:bg-gray-800' : 'bg-gray-300 cursor-not-allowed' %>"
                    <%= current_hold ? nil : 'disabled' %>>
              Hold Off
            </button>
          <% end %>
        </div>
        <p class="mt-3 text-xs text-gray-500">Commands publish <span class="font-mono">go_to_state</span> to the Snoo control topic and then refresh device state.</p>
      </div>
    </div>
  <% else %>
    <p class="text-sm text-gray-500">Connect to your Snoo first to enable runtime controls.</p>
  <% end %>
</div>
