<div class="max-w-6xl mx-auto px-4 py-8" data-controller="snoo">
  <h1 class="text-3xl font-bold mb-6">Snoo Debug Monitor</h1>

  <% if flash[:notice] %>
    <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4"><%= flash[:notice] %></div>
  <% end %>
  <% if flash[:alert] %>
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4"><%= flash[:alert] %></div>
  <% end %>

  <!-- Connection Panel -->
  <div class="bg-white shadow rounded-lg p-6 mb-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-xl font-semibold">Connection</h2>
      <div id="connection-status" data-snoo-target="connectionStatus"
           class="px-3 py-1 rounded-full text-sm font-medium <%= @connected ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' %>">
        <%= @connected ? "Connected" : "Disconnected" %>
      </div>
    </div>

    <% if @connected %>
      <%= form_with url: "/snoo/disconnect", method: :post, class: "inline" do %>
        <button type="submit" class="bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded">
          Disconnect
        </button>
      <% end %>
    <% elsif @credentials_configured %>
      <p class="text-sm text-gray-600 mb-4">
        Using Snoo credentials from Rails credentials.
      </p>
      <%= form_with url: "/snoo/connect", method: :post, class: "inline" do %>
        <button type="submit" class="bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded">
          Connect
        </button>
      <% end %>
    <% else %>
      <%= form_with url: "/snoo/connect", method: :post, class: "space-y-4" do %>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
            <input type="email" name="username" required autocomplete="email"
                   class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
                   placeholder="your@email.com">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
            <input type="password" name="password" required autocomplete="current-password"
                   class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
          </div>
        </div>
        <button type="submit" class="bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded">
          Connect
        </button>
      <% end %>
    <% end %>
  </div>

  <!-- Device Settings -->
  <div class="bg-white shadow rounded-lg p-6 mb-6">
    <details class="group">
      <summary class="flex cursor-pointer list-none items-center justify-between gap-4">
        <div>
          <h2 class="text-xl font-semibold">Device Settings</h2>
          <p class="text-sm text-gray-500">Collapsed by default to keep the live controls and event stream in view.</p>
        </div>
        <span class="rounded-full bg-gray-100 px-3 py-1 text-sm font-medium text-gray-700 transition group-open:bg-gray-200">
          <span class="group-open:hidden">Show</span>
          <span class="hidden group-open:inline">Hide</span>
        </span>
      </summary>

      <div class="mt-4">
        <% if @device_settings || @latest %>
          <%= render partial: "dashboard/device_settings", locals: { settings: @device_settings, event: @latest } %>
        <% else %>
          <p class="text-gray-500">No device settings available yet. Connect to your Snoo to load the latest device snapshot.</p>
        <% end %>
      </div>
    </details>
  </div>

  <!-- Current Status -->
  <div class="bg-white shadow rounded-lg p-6 mb-6">
    <h2 class="text-xl font-semibold mb-4">Current Status</h2>
    <div id="current-status" data-snoo-target="currentStatus">
      <%= render partial: "dashboard/current_status", locals: { event: @latest, connected: @connected } %>
    </div>
  </div>

  <!-- Event Log -->
  <%= turbo_frame_tag "event_log", data: { turbo_action: "advance" } do %>
    <div class="bg-white shadow rounded-lg p-6">
      <div data-snoo-target="pageState"
           data-page="<%= @pagy.page %>"
           data-page-size="<%= @pagy.limit %>"></div>

      <div class="flex items-center justify-between mb-4">
        <h2 class="text-xl font-semibold">Event Log</h2>
        <span class="text-sm text-gray-500" data-snoo-target="eventCount">
          Page <%= @pagy.page %> of <%= @pagy.pages %> • <%= @events.size %> events shown
        </span>
      </div>

      <div class="overflow-x-auto">
        <table class="min-w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200 text-left text-gray-600">
              <th class="py-2 px-3">Time</th>
              <th class="py-2 px-3">Gap</th>
              <th class="py-2 px-3">Event</th>
              <th class="py-2 px-3">State</th>
              <th class="py-2 px-3">Level</th>
              <th class="py-2 px-3">Hold</th>
              <th class="py-2 px-3">L Clip</th>
              <th class="py-2 px-3">R Clip</th>
              <th class="py-2 px-3">White Noise</th>
            </tr>
          </thead>
          <tbody id="event-log" data-snoo-target="eventLog">
            <% @events.each_with_index do |event, index| %>
              <%= render partial: "dashboard/event_row", locals: { event: event, previous_event: @events[index + 1] } %>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @pagy.pages > 1 %>
        <div class="mt-4 flex justify-center">
          <%= raw @pagy.series_nav %>
        </div>
      <% end %>

      <!-- Raw Payload Viewer -->
      <div class="mt-6">
        <h3 class="text-lg font-semibold mb-2">Raw Payload</h3>
        <pre id="raw-payload" data-snoo-target="rawPayload"
             class="bg-gray-900 text-green-400 p-4 rounded text-xs overflow-x-auto max-h-96 overflow-y-auto font-mono"><% if @latest&.raw_payload %><%= JSON.pretty_generate(JSON.parse(@latest.raw_payload)) rescue @latest.raw_payload %><% else %>Waiting for events...<% end %></pre>
      </div>
    </div>
  <% end %>
</div>
